/* On a Unix-ish platform? */
#cmakedefine UNIX 1

/* Is 'dirent.h' available? */
#cmakedefine HAVE_DIRENT_H 1

/* Missing time-related structs and functions. */
#cmakedefine NEED_STRUCT_TIMEVAL 1
#cmakedefine NEED_STRUCT_TIMEZONE 1
#cmakedefine NEED_GETTIMEOFDAY 1

/* Which curses library is being used? */
#cmakedefine HAVE_CURSES_LIB 1
#cmakedefine HAVE_NCURSES_LIB 1
#cmakedefine HAVE_PDCURSES_LIB 1

/* Sizes of the various data types. */
#define SIZEOF_INT @SIZEOF_INT@
#define SIZEOF_LONG @SIZEOF_LONG@
#define SIZEOF_LONG_LONG @SIZEOF_LONG_LONG@
